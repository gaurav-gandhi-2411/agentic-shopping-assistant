# Copy this file to .env.local and fill in the values.
#   cp .env.local.example .env.local
#
# .env.local is gitignored — never commit real credentials.
# See SETUP.md for full configuration instructions.

# Supabase project URL — found at: Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co

# Supabase anon/public key — found at: Settings → API → Project API keys → anon/public
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# FastAPI backend base URL (snitch service; used as fallback for authenticated path)
NEXT_PUBLIC_BACKEND_URL=http://localhost:8080

# Per-brand Cloud Run backend URLs (set to Cloud Run URLs in production)
NEXT_PUBLIC_SNITCH_BACKEND_URL=http://localhost:8000    # snitch Cloud Run service URL
NEXT_PUBLIC_MYNTRA_BACKEND_URL=http://localhost:8001    # myntra Cloud Run service URL
NEXT_PUBLIC_FLIPKART_BACKEND_URL=http://localhost:8002  # flipkart Cloud Run service URL

# Sentry error tracking (frontend).  Omit or leave blank to disable.
# NEXT_PUBLIC_SENTRY_DSN=https://your_key@oXXXXXX.ingest.sentry.io/XXXXXXX
