# API container only — exclude everything not needed by the server

# Streamlit UI (separate deployment)
spaces/

# Test infrastructure
tests/
scripts/
reports/

# Docs and notebooks
docs/
notebooks/
*.ipynb

# Model checkpoints and raw data
models/
data/                  # ALL local data — indices, CLIP, variant maps, raw — loaded from GCS at runtime
demo_indices/          # local experiment indices; never baked into the image

# Frontend build artefacts
frontend/node_modules/
frontend/.next/

# Python artefacts
**/__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
.eggs/

# Virtual environments
.venv/
venv/
env/

# Local config and secrets — CRITICAL: must never enter the image
.env
.env.*
*.env

# Local FAISS / parquet that may appear at repo root or scripts output
*.faiss
*.parquet
*.npy

# Dev tooling caches
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Version control
.git/
.gitignore

# Editor
.vscode/
.idea/
*.swp
