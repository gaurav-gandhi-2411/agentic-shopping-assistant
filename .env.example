# Copy this file to .env and fill in the values.
#   cp .env.example .env
#
# .env is gitignored — never commit real credentials.
# See SUPABASE_SETUP.md for DATABASE_URL instructions.
# See api/README.md for a full description of every variable.

# ── LLM provider ──────────────────────────────────────────────────────────────
# At least one key is required.  The active provider is set in config.yaml
# (llm.provider) and can be overridden at runtime via LLM_PROVIDER below.

GROQ_API_KEY=your_groq_api_key_here
# OPENROUTER_API_KEY=your_openrouter_api_key_here
# GEMINI_API_KEY=your_gemini_api_key_here

# ── Database ──────────────────────────────────────────────────────────────────
# Optional.  When set, conversations are persisted across restarts.
# When unset, the API uses an in-memory store (sessions lost on restart).
# Use the Supabase Transaction pooler URI (port 5432).
#
# DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres

# ── LLM provider override ─────────────────────────────────────────────────────
# Uncomment to override the provider from config.yaml at runtime.
# LLM_PROVIDER=groq

# ── Observability ─────────────────────────────────────────────────────────────
# LANGSMITH_API_KEY=your_langsmith_api_key_here
# LANGSMITH_PROJECT=agentic-shopping-assistant

# Sentry error tracking (backend).  Omit or leave blank to disable.
# SENTRY_DSN=https://your_key@oXXXXXX.ingest.sentry.io/XXXXXXX
#
# Expose /sentry-debug endpoint for ingestion verification (never in prod).
# SENTRY_DEBUG_ENDPOINT=true

# ── Supabase / JWT auth ───────────────────────────────────────────────────────
# Required in production.  Used to derive the JWKS URL for RS256 verification.
# SUPABASE_URL=https://<project-ref>.supabase.co

# JWT audience claim to verify against. Default: "authenticated".
# SUPABASE_JWT_AUD=authenticated

# Set to "true" to skip JWT verification entirely (local dev without Supabase).
# WARNING: never set this in production — all requests become unauthenticated.
# JWT_VERIFICATION_DISABLED=true

# ── API settings ─────────────────────────────────────────────────────────────
# LOG_LEVEL=INFO
# CORS_ORIGINS=http://localhost:8501,http://127.0.0.1:8501
#
# Per-user chat rate limit (requests per minute).  Default: 10.
# RATE_LIMIT_PER_MINUTE=10

# ── Phase F — Affiliate deep-link tags (OFF by default) ──────────────────────
#
# Per-store affiliate tags are configured via ASA_AFFILIATE_<STORE> env vars,
# where <STORE> is the uppercased store slug (e.g. SNITCH, FLIPKART).
# Format: "<mode>:<value>"
#
#   param:<querystring>
#     Appends a raw query-string fragment to the plain PDP URL.
#     Uses "?" when the URL has no existing query params (Myntra, Snitch,
#     Fashor, Powerlook, Virgio), or "&" when params are already present
#     (Flipkart URLs always have ?pid=…).
#     Example:
#       ASA_AFFILIATE_SNITCH=param:affid=FAKE_TAG_ID
#       ASA_AFFILIATE_FLIPKART=param:affid=FAKE_TAG_ID&utm_source=asa
#
#   wrap:<template>
#     URL-encodes the plain PDP URL and substitutes it into the {url}
#     placeholder in <template>.  Used for link-redirect affiliate networks.
#     The template MUST contain exactly one {url} placeholder.
#     Example:
#       ASA_AFFILIATE_MYNTRA=wrap:https://linksredirect.example.com/?pub=FAKE123&source=asa&url={url}
#
# When unset (the default), plain deep-links are returned unchanged.
# NEVER put real affiliate IDs in this file or commit them to the repo.
# All values below use clearly-marked FAKE placeholder values.
#
# ASA_AFFILIATE_MYNTRA=param:af_channel=FAKE_CHANNEL_ID
# ASA_AFFILIATE_FLIPKART=param:affid=FAKE_FLIPKART_AFFID
# ASA_AFFILIATE_SNITCH=param:affid=FAKE_SNITCH_AFFID
# ASA_AFFILIATE_FASHOR=param:affid=FAKE_FASHOR_AFFID
# ASA_AFFILIATE_POWERLOOK=param:affid=FAKE_POWERLOOK_AFFID
# ASA_AFFILIATE_VIRGIO=param:affid=FAKE_VIRGIO_AFFID
# ASA_AFFILIATE_MYNTRA=wrap:https://linksredirect.example.com/?pub=FAKE123&source=asa&url={url}
