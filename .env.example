# Copy this file to .env and fill in the values.
#   cp .env.example .env
#
# .env is gitignored — never commit real credentials.
# See SUPABASE_SETUP.md for DATABASE_URL instructions.
# See api/README.md for a full description of every variable.

# ── LLM provider ──────────────────────────────────────────────────────────────
# At least one key is required.  The active provider is set in config.yaml
# (llm.provider) and can be overridden at runtime via LLM_PROVIDER below.

GROQ_API_KEY=your_groq_api_key_here
# OPENROUTER_API_KEY=your_openrouter_api_key_here
# GEMINI_API_KEY=your_gemini_api_key_here

# ── Database ──────────────────────────────────────────────────────────────────
# Optional.  When set, conversations are persisted across restarts.
# When unset, the API uses an in-memory store (sessions lost on restart).
# Use the Supabase Transaction pooler URI (port 5432).
#
# DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres

# ── LLM provider override ─────────────────────────────────────────────────────
# Uncomment to override the provider from config.yaml at runtime.
# LLM_PROVIDER=groq

# ── Observability ─────────────────────────────────────────────────────────────
# LANGSMITH_API_KEY=your_langsmith_api_key_here
# LANGSMITH_PROJECT=agentic-shopping-assistant

# ── API settings ─────────────────────────────────────────────────────────────
# LOG_LEVEL=INFO
# CORS_ORIGINS=http://localhost:8501,http://127.0.0.1:8501
